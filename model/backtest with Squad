# ── Updated run_ablation() ────────────────────────────────────────────────

def run_ablation(df_games, start_year=2017, min_test_seasons=3,
                 squad_lookup=None):
    """
    For each feature group in ABLATION_GROUPS, run walk-forward backtest
    with that group dropped, compare to baseline.

    Returns DataFrame:
        group | accuracy_with | accuracy_without | delta | verdict
    """
    from model.predictor import train_models, predict_game, build_prediction_features

    # 1. Baseline (all features)
    baseline_acc = walk_forward_backtest(df_games, start_year, min_test_seasons,
                                         squad_lookup=squad_lookup)["accuracy"]

    results = []
    for group_name, group_features in ABLATION_GROUPS.items():
        # Check if any features from this group are actually in the model
        acc_without = walk_forward_backtest(
            df_games, start_year, min_test_seasons,
            squad_lookup=squad_lookup,
            drop_features=group_features     # existing param in walk_forward_backtest
        )["accuracy"]

        delta = acc_without - baseline_acc
        if delta < -0.005:
            verdict = "✅ Helps"
        elif delta > 0.005:
            verdict = "❌ Hurts"
        else:
            verdict = "➡️ Neutral"

        results.append({
            "Feature Group":  group_name,
            "Baseline":       f"{baseline_acc:.1%}",
            "Without":        f"{acc_without:.1%}",
            "Delta":          f"{delta:+.2%}",
            "Verdict":        verdict,
        })

    return pd.DataFrame(results)


